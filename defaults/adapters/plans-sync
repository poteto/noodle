#!/bin/sh
set -eu

PLANS_DIR="${NOODLE_PLANS_DIR:-brain/plans}"
INDEX_FILE="$PLANS_DIR/index.md"
[ -f "$INDEX_FILE" ] || exit 0

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

while IFS= read -r line || [ -n "$line" ]; do
  rel=$(printf '%s\n' "$line" | sed -nE 's#.*\[\[(plans/[0-9][0-9]-[^/]+/overview)\]\].*#\1#p')
  [ -n "$rel" ] || continue

  id=$(printf '%s\n' "$rel" | sed -nE 's#plans/([0-9][0-9])-.*#\1#p')
  dir="$PLANS_DIR/$(printf '%s\n' "$rel" | sed -E 's#^plans/##; s#/overview$##')"
  overview="$dir/overview.md"

  status="active"
  title="$(basename "$dir")"
  if [ -f "$overview" ]; then
    s=$(sed -nE 's/^status:[[:space:]]*(draft|active|done).*/\1/p' "$overview" | head -n1)
    [ -n "$s" ] && status="$s"
    h=$(sed -nE 's/^#[[:space:]]+(.+)/\1/p' "$overview" | head -n1)
    [ -n "$h" ] && title="$h"
  fi

  phases_json=""
  first_open=1
  if [ -f "$overview" ]; then
    while IFS= read -r pline || [ -n "$pline" ]; do
      case "$pline" in
        '- [x] '*|'- [X] '*|'- [ ] '*)
          pname=$(printf '%s\n' "$pline" | sed -E 's/.*—[[:space:]]*//; s/^[[:space:]]*//; s/[[:space:]]*$//')
          [ -n "$pname" ] || pname="phase"
          pstatus="pending"
          case "$pline" in
            '- [x] '*|'- [X] '*) pstatus="done" ;;
            '- [ ] '*)
              if [ $first_open -eq 1 ]; then
                pstatus="active"
                first_open=0
              fi
              ;;
          esac
          frag=$(printf '{"name":"%s","status":"%s"}' "$(json_escape "$pname")" "$pstatus")
          if [ -n "$phases_json" ]; then
            phases_json="$phases_json,$frag"
          else
            phases_json="$frag"
          fi
          ;;
      esac
    done < "$overview"
  fi

  [ -n "$phases_json" ] || phases_json='{"name":"phase-1","status":"active"}'
  printf '{"id":"%s","title":"%s","status":"%s","phases":[%s],"tags":[]}\n' \
    "$(json_escape "$id")" "$(json_escape "$title")" "$status" "$phases_json"
done < "$INDEX_FILE"
