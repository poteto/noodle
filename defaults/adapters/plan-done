#!/bin/sh
set -eu

id=${1:-}
[ -n "$id" ] || { echo "id required" >&2; exit 1; }
id2=$(printf '%02d' "$id")
PLANS_DIR="${NOODLE_PLANS_DIR:-brain/plans}"
INDEX_FILE="$PLANS_DIR/index.md"
plan_dir=$(find "$PLANS_DIR" -maxdepth 1 -type d -name "$id2-*" | head -n1)
[ -n "$plan_dir" ] || { echo "plan not found" >&2; exit 1; }

overview="$plan_dir/overview.md"
tmp="$overview.tmp"
sed 's/^status:[[:space:]]*active/status: done/' "$overview" > "$tmp"
mv "$tmp" "$overview"

if [ -f "$INDEX_FILE" ]; then
  tmp="$INDEX_FILE.tmp"
  sed "s/- \[ \] \[\[plans\/$id2-/- [x] [[plans\/$id2-/" "$INDEX_FILE" > "$tmp"
  mv "$tmp" "$INDEX_FILE"
fi

TODOS_FILE="${NOODLE_TODOS_FILE:-brain/todos.md}"
if [ -f "$TODOS_FILE" ]; then
  tmp="$TODOS_FILE.tmp"
  sed "s/^\([0-9][0-9]*\. \)\[ \]\(.*\[\[plans\/$id2-.*\/overview\]\].*\)$/\1[x]\2/" "$TODOS_FILE" > "$tmp"
  mv "$tmp" "$TODOS_FILE"
fi
