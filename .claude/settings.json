{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "go run -C $CLAUDE_PROJECT_DIR/old_noodle . worktree hook"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/inject-brain.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "brain/",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/auto-index-brain.sh"
          }
        ]
      }
    ],
    "Stop": []
  }
}
